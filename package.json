{
  "name": "blaze-creator-os",
  "version": "0.1.0",
  "private": true,
  "description": "Production foundation for Blaze Creator OS.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @blaze/web",
    "dev:web": "npm run dev --workspace @blaze/web",
    "dev:api": "npm run dev --workspace @blaze/api",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "prisma:generate": "npm run prisma:generate --workspace @blaze/api"
  },
  "engines": {
    "node": ">=20"
  }
}
